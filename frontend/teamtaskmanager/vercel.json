{
  "version": 2,
  "builds": [
    {
      "src": "frontend/teamtaskmanagement/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/teamtaskmanagement/dist/$1"
    }
  ]
}